# Environment for the redactor service. Installed to /etc/redactor/redactor.env
# (mode 0640, group redactor). provision.sh fills in a generated API key and the
# model path automatically; edit afterwards as needed.

# REQUIRED: comma-separated API keys. Generate with: openssl rand -hex 24
REDACTOR_API_KEYS=changeme

# REQUIRED: path to the GGUF model (set by provision.sh).
REDACTOR_MODEL_PATH=/var/lib/redactor/models/privacy-filter-q8.gguf

# Network. TLS is expected to terminate upstream (proxy / LB).
REDACTOR_LISTEN_ADDR=:8080

# Engine
REDACTOR_DEVICE=cpu
REDACTOR_WINDOW=0

# The redactor is CPU-bound. POOL_SIZE = number of model contexts = max
# server-side concurrency; N_THREADS = threads per forward pass. Aim for
#   POOL_SIZE * N_THREADS  ≈  CPU cores
# POOL_SIZE > 1 lets many small (per-text-node) redactions run in parallel,
# which is the main latency win for document redaction. BUT each context is a
# full model copy in RAM (q8 ≈ 1.5 GB), so provision RAM ≈ POOL_SIZE * model.
#
# Defaults below suit a 4-core / 6 GB box (2 contexts ≈ 3 GB). Scale both up
# with more cores and RAM (e.g. 8 cores / 12 GB → POOL_SIZE=4, N_THREADS=2).
REDACTOR_N_THREADS=2
REDACTOR_POOL_SIZE=2

# Redaction defaults
REDACTOR_DEFAULT_THRESHOLD=0.5
REDACTOR_MASK_STRING=[REDACTED]
# HMAC key for the "hash" redaction mode (optional). openssl rand -hex 32
REDACTOR_HASH_SECRET=

# Limits / timeouts
REDACTOR_MAX_BODY_BYTES=1048576
REDACTOR_READ_TIMEOUT=15s
REDACTOR_WRITE_TIMEOUT=30s
REDACTOR_IDLE_TIMEOUT=60s
